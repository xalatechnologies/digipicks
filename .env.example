# SaaS Boilerplate — Environment Configuration Template
# Copy this file to .env.local and fill in your values

# =============================================================================
# Convex Backend
# =============================================================================

# Option A: Convex Cloud (recommended for development)
# Run `npx convex dev` — it will set CONVEX_DEPLOYMENT automatically
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# Option B: Self-hosted Convex
# CONVEX_URL=https://your-convex-api.example.com
# VITE_CONVEX_URL=https://your-convex-api.example.com
# CONVEX_SITE_URL=https://your-convex-site.example.com
# CONVEX_SELF_HOSTED_URL=https://your-convex-api.example.com
# CONVEX_SELF_HOSTED_ADMIN_KEY=<from: docker compose exec backend ./generate_admin_key.sh>

# Convex Admin Key — CLI only (seeds, deploy). NEVER use VITE_ prefix
# CONVEX_ADMIN_KEY=

# Convex Deploy Key — used in CI for `npx convex deploy` and `--dry-run`
# Get from Convex dashboard → Settings → Deploy keys
# CONVEX_DEPLOY_KEY=

# =============================================================================
# App URLs (cross-linking between apps)
# =============================================================================

VITE_WEB_APP_URL=http://localhost:5190
VITE_DASHBOARD_URL=http://localhost:5180

# =============================================================================
# Platform Branding
# =============================================================================

# PLATFORM_NAME=My SaaS Platform
# VITE_PLATFORM_NAME=Xala Foundation
# VITE_PLATFORM_TAGLINE=Simple SAAS
# VITE_PLATFORM_DOMAIN=app.example.com
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=My Platform
# SUPPORT_EMAIL=support@example.com

# =============================================================================
# Legal Pages (privacy, terms, contact)
# =============================================================================

# VITE_PRIVACY_URL=/privacy
# VITE_TERMS_URL=/terms
# VITE_CONTACT_URL=/about

# =============================================================================
# Optional: Development Flags
# =============================================================================

# VITE_DEV_AUTH=true
# VITE_USE_MOCK_AUTH=true

# =============================================================================
# Optional: Error Tracking (Sentry)
# =============================================================================

# VITE_SENTRY_DSN=
# SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development

# =============================================================================
# Optional: Multi-tenant Configuration
# =============================================================================

# VITE_TENANT_ID=

# =============================================================================
# Optional: Maps
# =============================================================================

# VITE_MAPBOX_TOKEN=
# VITE_GOOGLE_PLACES_API_KEY=

# =============================================================================
# Optional: Altinn Integration (Norwegian market)
# =============================================================================

# VITE_ALTINN_ENABLED=false
# VITE_ALTINN_TOKEN_EXCHANGE_URL=
# VITE_ALTINN_AUTHORIZATION_URL=

# =============================================================================
# Backend Secrets (set via Convex Dashboard → Environment Variables)
# =============================================================================
#
# Auth providers:
# - BANKID_CLIENT_ID, BANKID_CLIENT_SECRET
# - VIPPS_CLIENT_ID, VIPPS_CLIENT_SECRET, VIPPS_SUBSCRIPTION_KEY, VIPPS_MSN
# - GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
# - AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID
#
# Email:
# - RESEND_API_KEY
#
# Payments:
# - STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
# - ADYEN_API_KEY, ADYEN_MERCHANT_ACCOUNT, ADYEN_HMAC_KEY
#
# Other:
# - NOTIFICATION_BCC (optional, comma-separated)
# - CORS_ORIGINS (optional, comma-separated production domains)
# - ICAL_DOMAIN (for calendar UID generation)
